NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/pepete
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48
JWT_EXPIRE=7d
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ─── Stripe (Pépète Plus subscription) ─────────────────────────────
# Keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring prices created in Stripe dashboard (Mode: subscription)
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx
# URL where the app/web receives success/cancel redirects
CLIENT_URL=http://localhost:8081
