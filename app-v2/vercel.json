{
  "name": "pepete-front",
  "version": 2,
  "buildCommand": "npx expo export --platform web && node scripts/inject-pwa-meta.js",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/blog/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/produit/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/marque/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/croquettes-:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/classement/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/ingredients-dangereux",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/comparatif/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/landing.html", "destination": "/landing.html" },
    { "source": "/indexnow.json", "destination": "/indexnow.json" },
    { "source": "/fef37dc422ec45c2bdae7c5a0e1f6a8e.txt", "destination": "/fef37dc422ec45c2bdae7c5a0e1f6a8e.txt" },
    { "source": "/blog/:path*", "destination": "/blog/:path*" },
    { "source": "/produit/:barcode", "destination": "/api/seo?type=product&barcode=:barcode" },
    { "source": "/marque/:brand", "destination": "/api/seo?type=brand&brand=:brand" },
    { "source": "/croquettes-:animal", "destination": "/api/seo?type=animal&animal=:animal" },
    { "source": "/classement/:animal", "destination": "/api/seo?type=ranking&animal=:animal" },
    { "source": "/ingredients-dangereux", "destination": "/api/seo?type=dangerous" },
    { "source": "/comparatif/:slug", "destination": "/api/seo?type=comparatif&slug=:slug" },
    { "source": "/sitemap.xml", "destination": "/api/seo?type=sitemap-index" },
    { "source": "/sitemap-products-:page.xml", "destination": "/api/seo?type=sitemap-products&page=:page" },
    { "source": "/sitemap-brands.xml", "destination": "/api/seo?type=sitemap-brands" },
    { "source": "/sitemap-pages.xml", "destination": "/api/seo?type=sitemap-pages" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
